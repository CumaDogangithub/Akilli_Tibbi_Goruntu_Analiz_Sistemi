# Herkesin kendi bilgisayarındaki lokal test sonuçları (GitHub'ı kirletmemesi için)
# Not: Klasörün kendisi GitHub'a gitsin ama içindeki resimler gitmesin diye .gitkeep'i hariç tutuyoruz
static/img/analiz_sonuclari/*
!static/img/analiz_sonuclari/.gitkeep

# Yüklenen hasta görüntüleri (KVKK gereği repo'da olmamalı, her geliştiricide kendi test verisi olur)
static/uploads/*
!static/uploads/.gitkeep

# Çalışma anında üretilen SQLite veritabanı (her makinede ayrı, push edilmemeli)
veritabani/*.db
veritabani/*.sqlite
veritabani/*.sqlite3

# Runtime PDF raporları (dinamik üretiliyor — orijinal döküman PDF'leri repo'da kalır)
