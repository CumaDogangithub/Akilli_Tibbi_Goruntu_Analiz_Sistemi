# ============================================================
# ATGAS — Ortam Değişkenleri Şablonu (.env.example)
# ============================================================
# Bu dosyayı `.env` olarak kopyalayın ve değerleri kendi yapılandırmanıza göre
# güncelleyin. `.env` dosyası `.gitignore`'a eklidir → secret'lar repo'ya gitmez.
#
# Hızlı başlangıç:
#   cp .env.example .env
#   # ATGAS_SECRET üret: python -c "import secrets; print(secrets.token_urlsafe(32))"
#   # DATABASE_URL'i Supabase Dashboard'dan al

# ============================================================
# 1) FLASK
# ============================================================
# Cryptographically secure rastgele anahtar (cookie + session imzalama için).
# Üretmek için:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
ATGAS_SECRET=degistir-bu-degeri-uretimde-rastgele-uzun-bir-anahtarla
FLASK_ENV=development

# ============================================================
# 2) VERİTABANI (PostgreSQL — ZORUNLU)
# ============================================================
# SQLite desteği kaldırıldı. Önerilen: Supabase ücretsiz tier (500 MB).
#
# Supabase'den connection string almak için:
#   Dashboard → Project Settings → Database → Connection string → URI
#   "Transaction pooler" sekmesini seç (port 6543, IPv4 destekli)
#
# Format:
#   postgresql://postgres.<PROJECT-REF>:<DB-PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres
#
# Örnek:
#   postgresql://postgres.xyzabcdefg:gizli_sifre@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
#
# Cloud (Render/Railway/Heroku) genelde `postgres://` ile başlar — kod otomatik çevirir.
# Şifrede @ # % gibi özel karakter varsa URL-encode edin (@ → %40 vb.)
DATABASE_URL=postgresql://postgres.PROJECT-REF:DB-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# ============================================================
# 3) DOSYA YOLLARI (Taşınabilirlik)
# ============================================================
# Veritabanına yalnızca DOSYA ADI yazılır (örn: "orig_xxx.png").
# Diskteki tam yol = ANA_DIZIN + bu sabit + dosya_adi
# Bu sayede DB kayıtları başka makinede / cloud'da geçerli kalır.
UPLOADS_DIR=static/uploads
RESULTS_DIR=static/img/analiz_sonuclari
