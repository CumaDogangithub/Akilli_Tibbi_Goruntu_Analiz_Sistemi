# ============================================================
# ATGAS — Ortam Değişkenleri Şablonu (.env.example)
# ============================================================
# Bu dosyayı `.env` olarak kopyalayın ve değerleri kendi yapılandırmanıza göre
# güncelleyin. `.env` dosyası `.gitignore`'a eklidir → secret'lar repo'ya gitmez.
#
# Hızlı başlangıç:
#   cp .env.example .env
#   # ATGAS_SECRET üret: python -c "import secrets; print(secrets.token_urlsafe(32))"
#   # DATABASE_URL'i Supabase Dashboard'dan al

# ============================================================
# 1) FLASK
# ============================================================
# Cryptographically secure rastgele anahtar (cookie + session imzalama için).
# Üretmek için:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
ATGAS_SECRET=degistir-bu-degeri-uretimde-rastgele-uzun-bir-anahtarla

# Çalışma ortamı: development | production
FLASK_ENV=development

# Sunucu host ve port (lokal: 127.0.0.1 / production: 0.0.0.0)
FLASK_HOST=127.0.0.1
FLASK_PORT=5001

# Debug modu: true / false (üretimde HER ZAMAN false)
FLASK_DEBUG=false

# ============================================================
# 2) VERİTABANI (PostgreSQL — ZORUNLU)
# ============================================================
# SQLite desteği kaldırıldı. Önerilen: Supabase ücretsiz tier (500 MB).
#
# Supabase'den connection string almak için:
#   Dashboard → Project Settings → Database → Connection string → URI
#   "Transaction pooler" sekmesini seç (port 6543, IPv4 destekli)
#
# Format:
#   postgresql://postgres.<PROJECT-REF>:<DB-PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres
#
# Cloud (Render/Railway/Heroku) genelde `postgres://` ile başlar — kod otomatik çevirir.
# Şifrede @ # % gibi özel karakter varsa URL-encode edin (@ → %40 vb.)
DATABASE_URL=postgresql://postgres.PROJECT-REF:DB-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# ============================================================
# 3) DOSYA YOLLARI (Taşınabilirlik)
# ============================================================
# Veritabanına yalnızca DOSYA ADI yazılır (örn: "orig_xxx.png").
# Diskteki tam yol = ANA_DIZIN + bu sabit + dosya_adi
# Bu sayede DB kayıtları başka makinede / cloud'da geçerli kalır.
UPLOADS_DIR=static/uploads
RESULTS_DIR=static/img/analiz_sonuclari

# ============================================================
# 4) UYGULAMA AYARLARI
# ============================================================
# Maksimum yüklenebilen dosya boyutu (MB) — DICOM dosyaları büyük olabilir.
MAX_UPLOAD_MB=50

# ============================================================
# 5) DEMO HESAPLAR — ROL BAZLI
# ============================================================
# İlk kurulumda her rol için otomatik bir demo hesap oluşturulur (yoksa).
# Üretimde bu değerleri değiştirin veya admin paneli üzerinden yenilerini ekleyin.

# Doktor — Görüntü yükler, AI analizi yapar, raporları yönetir
DEMO_DOKTOR_AD="Dr. Demo"
DEMO_DOKTOR_EPOSTA=doktor@atgas.local
DEMO_DOKTOR_SIFRE=123456
DEMO_DOKTOR_BRANS=Radyoloji

# Yönetici (admin) — Kullanıcı ekler, raporları yönetir
DEMO_ADMIN_AD="Sistem Yöneticisi"
DEMO_ADMIN_EPOSTA=admin@atgas.local
DEMO_ADMIN_SIFRE=admin123
DEMO_ADMIN_BRANS=Yönetim

# Radyolog — Tüm raporları inceler, anomali işaretlemelerini değerlendirir
DEMO_RADYOLOG_AD="Dr. Radyolog"
DEMO_RADYOLOG_EPOSTA=radyolog@atgas.local
DEMO_RADYOLOG_SIFRE=radyolog123
DEMO_RADYOLOG_BRANS=Radyoloji

# Akademisyen — Model performans metriklerini ve TensorBoard'u izler
DEMO_AKADEMISYEN_AD="Prof. Akademisyen"
DEMO_AKADEMISYEN_EPOSTA=akademisyen@atgas.local
DEMO_AKADEMISYEN_SIFRE=akademisyen123
DEMO_AKADEMISYEN_BRANS="Tıbbi Görüntüleme AR-GE"

# ============================================================
# 6) TENSORBOARD (Akademisyen paneli)
# ============================================================
# Akademisyen panelinde model eğitim grafiklerini sunar.
# Loglar 'modul_yapay_zeka/logs/' altından okunur.
TENSORBOARD_PORT=6006

# Sub-path proxy modu — lokal vs sunucu farkını tek anahtar yönetir:
#   - LOKAL DEV (Windows/Mac/Linux, doğrudan 'python app.py'):
#       BOŞ BIRAK  → TB http://127.0.0.1:6006/ adresinden direkt sunulur.
#   - SUNUCU (Docker + nginx + Cloudflare):
#       'tensorboard' yaz  → TB https://<domain>/tensorboard/ üzerinden sunulur.
#       Cloudflare port 6006'yı forward etmediği için sub-path zorunlu;
#       nginx config'inde de matching `location /tensorboard/` bloğu olmalı.
# sunucu için -> TENSORBOARD_PATH_PREFIX=tensorboard
TENSORBOARD_PATH_PREFIX=